<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!--
        TOMCAT DEPLOYMENT — web.xml
        ===========================================
        Jersey is registered here as a servlet.
        The URL prefix /api/v1 comes from @ApplicationPath
        in SmartCampusApplication.java.
        url-pattern is /api/v1/* so Jersey handles /api/v1/... routes.

        Final base URL: http://localhost:8080/api/v1
        (WAR is named ROOT.war so context path is empty)
    -->

    <servlet>
        <servlet-name>SmartCampusAPI</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>javax.ws.rs.Application</param-name>
            <param-value>com.smartcampus.application.SmartCampusApplication</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>SmartCampusAPI</servlet-name>
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>
